{
  "name": "kapimart-github",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "i18n:extract": "neokapi-i18n extract --config neokapi-i18n.config.json --src \"src/**/*.{tsx,jsx}\" --out i18n",
    "i18n:compile": "neokapi-i18n compile i18n/src i18n/de i18n/fr i18n/ja i18n/nb --out public/translations --review",
    "i18n:ship": "kapi status --ship --emit public/ship.json"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@neokapi/i18n-react-lint": "^0.1.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "@neokapi/i18n-react": "^1.2.3"
  }
}
