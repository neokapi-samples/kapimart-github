{
  "name": "kapimart-github",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "i18n:extract": "kapi-react extract --config kapi-react.config.json --src \"src/**/*.{tsx,jsx}\" --out i18n/ --target-locale qps",
    "i18n:compile": "for d in i18n-*; do [ -d \"$d\" ] && kapi-react compile \"$d\" --out public/translations; done"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "@neokapi/kapi-react": "^1.1.0"
  }
}
